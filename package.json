{
  "name": "cesium-client-project",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-cesium.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist",
    "convert-obj": "npx obj2gltf -i public/models/BL_obj_001_1.obj -o public/models/BL_obj_001_1.glb",
    "convert-all": "node scripts/convert-all-obj.js",
    "fetch-sea": "node scripts/fetch-osm-water.js && node scripts/osm-to-sea-geojson.js",
    "fetch-port": "node scripts/fetch-osm-port-small.js && node scripts/osm-to-port-geojson.js"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "obj2gltf": "^3.2.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "cesium": "1.141.0"
  }
}
